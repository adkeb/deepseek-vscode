{
  "root": true,
  "env": {
    "es2021": true,
    "node": true
  },
  "ignorePatterns": [
    "out",
    "node_modules",
    "backend",
    "浏览器插件"
  ],
  "overrides": [
    {
      "files": [
        "src/**/*.ts"
      ],
      "parser": "@typescript-eslint/parser",
      "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
      },
      "plugins": [
        "@typescript-eslint"
      ],
      "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
      ]
    },
    {
      "files": [
        "src/webview/*.js"
      ],
      "env": {
        "browser": true,
        "node": false
      },
      "globals": {
        "acquireVsCodeApi": "readonly"
      },
      "extends": [
        "eslint:recommended"
      ]
    }
  ]
}
